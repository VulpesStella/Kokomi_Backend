        // 构建用于凹凸图的数据模型：越大排名越靠前 
        const buildRankModel = (model) => {
          //取出所有日期键
          const keys = model?.keys ?? [];

          //取出各服务器数据值
          const series = model?.series ?? [];

          // 所有服务器名字和值
          const names = series.map(s => s.name);

          //映射所有服务器名字+对应数据
          const dataByName = new Map(series.map(s => [s.name, (s.data || []).map(toNumber)]));

          // 初始化 rank 每条线
          const rankByName = new Map(names.map(n => [n, Array(keys.length).fill(null)]));

          for (let i = 0; i < keys.length; i++) {
            // 取各自对应数据
            const items = names.map(n => ({
              name: n,
              v: dataByName.get(n)?.[i] ?? null
            }));

            // 排数据
            items.sort((a, b) => {
              const av = a.v ?? -Infinity;
              const bv = b.v ?? -Infinity;
              if (bv !== av) return bv - av;
              return a.name.localeCompare(b.name);
            });

            // 并列值一起使用同一个名次
            let rank = 1;
            for (let idx = 0; idx < items.length; idx++) {
              if (idx > 0) {
                const prev = items[idx - 1].v ?? -Infinity;
                const cur = items[idx].v ?? -Infinity;
                if (cur !== prev) rank = idx + 1;
              }
              rankByName.get(items[idx].name)[i] = rank;
            }
          }

          return {
            keys,
            maxRank: names.length,
            series: names.map(n => ({
              name: n,
              data: rankByName.get(n) ?? []
            }))
          };
        };

        const buildBumpOption = (model, themeKey = "carnival", isDark = false) => {
          const theme = BUMP_THEMES[themeKey] ?? BUMP_THEMES.carnival;
          const ranked = buildRankModel(model);

          const axisText = isDark ? "rgba(255,255,255,0.85)" : "rgba(0,0,0,0.75)";
          const splitLine = isDark ? "rgba(255,255,255,0.10)" : "rgba(0,0,0,0.06)";

          return {
            tooltip: { trigger: "axis" },
            grid: { left: 56, right: 70, top: 30, bottom: 34 },

            legend: { top: 0, textStyle: { color: axisText } },

            xAxis: {
              type: "category",
              data: ranked.keys,
              axisLabel: { color: axisText },
              axisLine: { lineStyle: { color: splitLine } },
              axisTick: { show: false }
            },
            yAxis: {
              type: "value",
              inverse: true,          // 1 rank 在上
              min: 1,
              max: ranked.maxRank,
              interval: 1,
              axisLabel: { color: axisText, formatter: v => `#${v}` },
              splitLine: { lineStyle: { color: splitLine } }
            },

            animationDuration: 1200,
            animationEasing: "cubicOut",

            series: ranked.series.map((s, idx) => ({
              name: s.name,
              type: "line",
              data: s.data,
              smooth: 0.35,
              showSymbol: false,
              connectNulls: true,

              lineStyle: {
                width: 3,
                color: hGrad(theme.lineStops)
              },
              areaStyle: {
                color: vGrad(theme.areaStops)
              },

              endLabel: {
                show: true,
                formatter: p => p.seriesName,
                color: axisText,
                valueAnimation: true
              },
              emphasis: { focus: "series" }
            }))
          };
        };

        //#endregion



        //#region onMounted
        onMounted(() => {
          const todayModel = apiData.value.metrics.api_request_today;
          const data30dayModel = apiData.value.metrics.api_request_30d;
          const celery30dayModel = apiData.value.metrics.celery_tasks_30d;
          const calls14d = apiData.value.metrics.api_calls_14d;
          const fail14d = apiData.value.metrics.api_failed_rate_14d;
          if (calls14d && chartApiCalls14dEl.value) {
            chartApiCalls14d = echarts.init(chartApiCalls14dEl.value);
            chartApiCalls14d.setOption(buildBumpOption(calls14d, "carnival", false));
          }

          if (fail14d && chartApiFailedRate14dEl.value) {
            chartApiFailedRate14d = echarts.init(chartApiFailedRate14dEl.value);
            chartApiFailedRate14d.setOption(buildBumpOption(fail14d, "ocean", false));
          }
          if (!todayModel || !chartTodayEl.value) return;
          if (!data30dayModel || !chart30dayEl.value) return;

          if (!celery30dayModel || !celery30dayEl.value) return;

          chartToday = echarts.init(chartTodayEl.value);
          chartToday.setOption(buildLineBars(todayModel, "aurora"));
          chart30day = echarts.init(chart30dayEl.value);
          chart30day.setOption(buildLineBars(data30dayModel, "sunset"));

          celery30day = echarts.init(celery30dayEl.value);
          celery30day.setOption(buildLineBars(celery30dayModel, "sea"));

          window.addEventListener("resize", handleResize1);
          window.addEventListener("resize", handleResize2);
          window.addEventListener("resize", handleResize3);
          window.addEventListener("resize", () => {
            chartApiCalls14d?.resize();
            chartApiFailedRate14d?.resize();
          });
        });
        //#endregion

        onBeforeUnmount(() => {
          window.removeEventListener("resize", handleResize);
          chartToday && chartToday.dispose(); // 释放资源避免泄漏
          chartToday = null;
        });

        return { apiData, todayStatsList, chartTodayEl, chart30dayEl, celery30dayEl, chartApiCalls14dEl,chartApiFailedRate14dEl };
      }
    });

    app.use(antd);
    app.mount('#app');
  </script>
  <style>
    .chart {
      min-height: 260px;
      width: 100%;
    }
  </style>
}
